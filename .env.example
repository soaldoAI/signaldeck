# SignalDeck environment configuration.
# Copy to .env and adjust. Never commit .env.

# --- Database -------------------------------------------------------------
DATABASE_URL="postgresql://signaldeck:signaldeck@localhost:5432/signaldeck"

# --- Application ----------------------------------------------------------
# Base URL the app is served from (used in links inside briefing emails).
APP_URL="http://localhost:3000"

# --- SMTP (outbound mail: daily briefings) ---------------------------------
# Defaults match the bundled Mailpit dev server (docker compose up).
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="SignalDeck <briefing@localhost>"

# --- AI provider (configure ONE; see docs when Phase 3 lands) ---------------
# Supported: anthropic | openai | ollama
AI_PROVIDER="ollama"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"

# --- Google OAuth (Gmail + Calendar connectors, Phase 4-5) ------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
