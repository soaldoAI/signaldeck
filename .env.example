# SignalDeck environment configuration.
# Copy to .env and adjust. Never commit .env.
#
# You normally only need to touch this file once. AI provider and SMTP
# credentials are configured in the setup wizard (and stored encrypted
# in the database) — you should not need to hand-edit API keys here.

# --- Database -------------------------------------------------------------
DATABASE_URL="postgresql://signaldeck:signaldeck@localhost:5432/signaldeck"

# --- Application ----------------------------------------------------------
# Base URL the app is served from (used in links inside briefing emails).
APP_URL="http://localhost:3000"

# Secret used to encrypt stored credentials (AI keys, SMTP password) at
# rest. MUST be set and kept stable — changing it makes existing stored
# secrets undecryptable. Generate one with:  openssl rand -base64 32
# The bundled start script (./scripts/start.sh) generates this for you.
ENCRYPTION_KEY=""

# Disable Next.js anonymous telemetry. SignalDeck makes no phone-home
# promises to its users, so we keep the build/runtime quiet too.
NEXT_TELEMETRY_DISABLED="1"

# --- Optional defaults ----------------------------------------------------
# These pre-fill the setup wizard but are not required. The wizard is the
# source of truth; values it saves live (encrypted) in the database.
#
# SMTP host/port are intentionally left UNSET here. Leaving them blank lets
# each environment resolve the right value automatically: Docker Compose
# defaults the host to the bundled `mailpit` service, while local `npm run
# dev` falls back to `localhost`. Only override if you point at your own
# mail server (the wizard is the normal way to do that).
# SMTP_HOST=""
# SMTP_PORT="1025"
SMTP_FROM="SignalDeck <briefing@localhost>"

# Ollama (local AI). Leave UNSET: Docker defaults to host.docker.internal
# (Ollama runs on your host, not in the container), local dev falls back to
# localhost. Set it only to point at a remote Ollama server.
# To use Ollama: install it (https://ollama.com), then `ollama pull llama3.1`.
# OLLAMA_BASE_URL=""

# Google OAuth (Gmail + Calendar connectors, Phase 4-5).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Telegram (read your own chats). Get these from https://my.telegram.org →
# API development tools. Then run `npm run telegram:login` once. See
# docs/telegram-setup.md.
TELEGRAM_API_ID=""
TELEGRAM_API_HASH=""
