// SignalDeck database schema.
//
// Models are added milestone by milestone (see ROADMAP.md).
// Phase 2 introduces the single admin user, sessions, and settings.
// Phase 4+ introduce connectors, messages, and actions.
//
// The connection URL lives in prisma.config.ts (CLI) and
// src/server/db/client.ts (runtime), per Prisma 7 conventions.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// The administrator of this SignalDeck instance. SignalDeck is
/// single-tenant and local-first: one instance serves one person, so
/// there is exactly one User row. Modelled as a table (not a config
/// value) so sessions and, later, per-user connector ownership have a
/// stable foreign key.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  accounts     ConnectorAccount[]
  rules        Rule[]

  @@map("users")
}

/// A logged-in browser session. The cookie holds an opaque random
/// token; only its SHA-256 hash is stored here, so a database leak
/// cannot be used to impersonate the user.
model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

/// A learned preference / rule the user has given SignalDeck (e.g. "mute
/// newsletters from X", "Cameron is always high priority"). The classifier
/// consults these on every message, so SignalDeck visibly learns. Stored
/// locally; never leaves the machine.
model Rule {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// What the user said, verbatim — kept for transparency and editing.
  text      String
  /// mute | priority | note — how the classifier applies it.
  kind      String   @default("note")
  /// Free-form target the rule is about (a sender, domain, topic…).
  subject   String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("rules")
}

/// Key-value application settings (AI provider, SMTP, …). A flat store
/// keeps the schema stable as configuration grows — new settings need
/// no migration. Secret values (API keys, SMTP password) are encrypted
/// at rest; `encrypted` records whether `value` is ciphertext. The
/// typed accessor in src/server/settings/ owns which keys are secret.
model Setting {
  key       String   @id
  value     String
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("settings")
}

/// A connected external account (Gmail, Google Calendar, …). OAuth tokens
/// are stored encrypted at rest (the connector code en/decrypts them). One
/// row per (user, connector). `status`/`detail` drive the dashboard health
/// indicator; `cursor` tracks incremental sync position.
model ConnectorAccount {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectorId  String // "gmail", "google_calendar", …
  externalId   String // provider account id (e.g. Google sub)
  label        String // shown in the UI, e.g. the email address
  status       String    @default("connected") // connected | needs_attention | disconnected
  detail       String    @default("")
  accessToken  String // encrypted
  refreshToken String // encrypted
  tokenExpiry  DateTime?
  scope        String    @default("")
  cursor       String? // incremental sync position (e.g. latest message timestamp)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  events       CalendarEvent[]

  // Keyed by externalId so a user can connect several accounts of the same
  // kind (e.g. work + personal Gmail).
  @@unique([userId, connectorId, externalId])
  @@index([userId])
  @@map("connector_accounts")
}

/// A normalised message pulled from a connector. The unified cross-source
/// model is finalised in Phase 6; this is the first cut, populated by the
/// Gmail connector. Deduplicated per account by provider message id.
model Message {
  id          String           @id @default(cuid())
  accountId   String
  account     ConnectorAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  connectorId String // denormalised source for cross-account queries
  externalId  String // provider message id
  threadId    String?
  fromName    String           @default("")
  fromEmail   String           @default("")
  subject     String           @default("")
  snippet     String           @default("")
  receivedAt  DateTime
  createdAt   DateTime         @default(now())
  /// When the user marked this handled; dismissed items drop out of the
  /// brief (until newer activity in the thread brings it back).
  dismissedAt DateTime?
  insight     MessageInsight?

  @@unique([accountId, externalId])
  @@index([accountId, receivedAt])
  @@map("messages")
}

/// The AI's read of a single message — what it is, what (if anything) the
/// user must do, and how to triage it. Produced by the classification
/// engine (src/server/intelligence/) via the configured AI provider. One
/// row per message; absence means "not yet classified".
model MessageInsight {
  id        String   @id @default(cuid())
  messageId String   @unique
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  /// needs_reply | waiting | urgent | fyi | ignore
  category  String
  /// high | medium | low — how much this needs the user's attention.
  priority  String   @default("medium")
  /// One-line plain-language summary of what this message is.
  summary   String   @default("")
  /// The concrete next action for the user, or "" if none.
  action    String   @default("")
  /// Which AI model produced this, for transparency/debugging.
  model     String   @default("")
  createdAt DateTime @default(now())

  @@index([category])
  @@map("message_insights")
}

/// An upcoming calendar event pulled from a connector (Google Calendar in
/// Phase 5). Feeds the "what your day requires" half of the briefing.
/// Deduplicated per account by provider event id.
model CalendarEvent {
  id          String           @id @default(cuid())
  accountId   String
  account     ConnectorAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  connectorId String
  externalId  String // provider event id
  title       String           @default("(no title)")
  location    String           @default("")
  organizer   String           @default("")
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@unique([accountId, externalId])
  @@index([accountId, startsAt])
  @@map("calendar_events")
}
